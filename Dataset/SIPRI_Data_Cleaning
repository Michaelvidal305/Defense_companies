SQLite studio data cleaning for SIPRI top 100 Defense Companies Official List

-- 1. CREATE RAW TABLE (MATCHES CSV EXACTLY)
------------------------------------------------------------
CREATE TABLE sipri_raw (
    rank_2023      INTEGER,
    rank_2022      INTEGER,
    company_name   TEXT,
    country        TEXT,
    arms_rev_2023  TEXT,
    arms_rev_2022  TEXT,
    total_rev_2023 TEXT,
    arms_rev_pct   TEXT
);

-- IMPORT CSV INTO sipri_raw USING SQLiteStudio GUI 

------------------------------------------------------------
-- 2. CREATE CLEAN TABLE WITH PROPER DATA TYPES
------------------------------------------------------------

CREATE TABLE sipri_clean ( 
  rank_2023 INTEGER, 
  rank_2022 INTEGER, 
  company_name TEXT, 
  country TEXT, 
  arms_rev_2023 REAL, 
  arms_rev_2022 REAL, 
  total_rev_2023 REAL, 
  arms_rev_pct REAL 
);

-- IMPORT CSV INTO sipri_clean USING SQLiteStudio GUI 

------------------------------------------------------------
3. Insert cleaned data
-- Fixes:
-- • Removes commas
-- • Converts '' → NULL
-- • Converts '90.00%' → 0.90
-- • Removes non‑breaking spaces from country names
-- • Converts all numeric fields to REAL
------------------------------------------------------------
INSERT INTO sipri_clean SELECT rank_2023,
                               rank_2022,
                               TRIM(company_name) AS company_name,-- Remove NBSP (CHAR(160)) and trim
                               TRIM(REPLACE(country, CHAR(160), '') ) AS country,-- Convert numeric strings → REAL
                               CASE WHEN arms_rev_2023 = '' THEN NULL ELSE REPLACE(arms_rev_2023, ',', '') * 1.0 END AS arms_rev_2023,
                               CASE WHEN arms_rev_2022 = '' THEN NULL ELSE REPLACE(arms_rev_2022, ',', '') * 1.0 END AS arms_rev_2022,
                               CASE WHEN total_rev_2023 = '' THEN NULL ELSE REPLACE(total_rev_2023, ',', '') * 1.0 END AS total_rev_2023,-- Convert "90.00%" → 0.90
                               CASE WHEN arms_rev_pct IS NULL OR
                                         arms_rev_pct = '' THEN NULL ELSE REPLACE(REPLACE(arms_rev_pct, '%', ''), ',', '') / 100.0 END AS arms_rev_pct
                          FROM sipri_raw;

