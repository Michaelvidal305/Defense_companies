6. Add derived columns (Arms Revenue Percentage Growth, Arms Absolute Growth, Ranks Change
------------------------------------------------------------

-- These are extremely useful for analysis and dashboards.
-- arms_rev_growth → percentage growth between years 2022 to 2023
-- arms_rev_growth_usd → absolute growth in USD millions between years 2022 to 2023
-- rank_change → movement in ranking between years 2022 to 2023

ALTER TABLE sipri_clean ADD COLUMN arms_rev_growth REAL;
ALTER TABLE sipri_clean ADD COLUMN rank_change INTEGER;
ALTER TABLE sipri_clean ADD COLUMN arms_rev_growth_usd REAL;

UPDATE sipri_clean
   SET arms_rev_growth = CASE WHEN arms_rev_2022 IS NULL OR
                                   arms_rev_2022 = 0 THEN NULL ELSE (arms_rev_2023 - arms_rev_2022) / arms_rev_2022 END,
       rank_change = rank_2022 - rank_2023;

UPDATE sipri_clean
SET arms_rev_growth_usd =
    CASE
        WHEN arms_rev_2023 IS NULL OR arms_rev_2022 IS NULL THEN NULL
        ELSE arms_rev_2023 - arms_rev_2022
    END;

