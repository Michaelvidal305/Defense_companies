5. Standardize company name 
------------------------------------------------------------

UPDATE sipri_clean
SET company_name = TRIM(
        REPLACE(
            REPLACE(
                REPLACE(
                    REPLACE(
                        REPLACE(company_name, CHAR(160), ''),   -- remove NBSP
                    ' e', ''),                                  -- remove trailing " e"
                ' f', ''),                                      -- remove trailing " f"
            ' g', ''),                                          -- remove trailing " g"
        ' i', '')                                               -- remove trailing " i"
    );

